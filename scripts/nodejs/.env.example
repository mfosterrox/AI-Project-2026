# GraphQL scripts (githubGraphQLApiCallsDO_V2.js / DO_V3.js): classic or fine-grained PAT with repo read access.
TOKEN=

# Rows from scripts/nodejs/repos/*.csv to process (inclusive START through END; see slice in githubGraphQLApiCallsDO_V3.js).
START=0
END=50

# V2 only: delay in ms between GraphQL requests (respect GitHub rate limits on a single machine).
LOOPDELAY=1000

# getting_repos_v2.js (REST search): optional OAuth App credentials from GitHub Developer Settings.
CLIENT_ID=
CLIENT_SECRET=
